{
  "_comment": "OpenClaw config template. Installed to ~/.openclaw/openclaw.json by scripts/setup-openclaw.sh",
  "_placeholders": {
    "{{HOME}}": "your home directory (auto-substituted)",
    "{{OLLAMA_MODEL}}": "default model e.g. qwen3.5:397b-cloud or llama3.2:3b",
    "{{GATEWAY_TOKEN}}": "auto-generated by openclaw on first run — leave as-is"
  },

  "agents": {
    "defaults": {
      "model": {
        "primary": "ollama/{{OLLAMA_MODEL}}"
      },
      "workspace": "{{HOME}}/.openclaw/workspace"
    }
  },
  "commands": {
    "native": "auto",
    "nativeSkills": "auto",
    "ownerDisplay": "raw",
    "restart": true
  },
  "gateway": {
    "auth": {
      "mode": "token",
      "token": "{{GATEWAY_TOKEN}}"
    },
    "bind": "loopback",
    "mode": "local",
    "port": 18789,
    "tailscale": {
      "mode": "off",
      "resetOnExit": false
    }
  },
  "models": {
    "mode": "merge",
    "providers": {
      "ollama": {
        "api": "ollama",
        "apiKey": "ollama-local",
        "baseUrl": "http://127.0.0.1:11434",
        "models": [
          {
            "contextWindow": 262144,
            "cost": {
              "cacheRead": 0,
              "cacheWrite": 0,
              "input": 0,
              "output": 0
            },
            "id": "{{OLLAMA_MODEL}}",
            "input": ["text", "image"],
            "maxTokens": 8192,
            "name": "{{OLLAMA_MODEL}}",
            "reasoning": true
          }
        ]
      }
    }
  },
  "plugins": {
    "allow": ["openclaw-web-search"],
    "entries": {
      "ollama": {
        "config": {},
        "enabled": true
      },
      "openclaw-web-search": {
        "enabled": true
      }
    },
    "installs": {
      "openclaw-web-search": {
        "installPath": "{{HOME}}/.openclaw/extensions/openclaw-web-search",
        "source": "npm",
        "spec": "@ollama/openclaw-web-search"
      }
    }
  },
  "session": {
    "dmScope": "per-channel-peer"
  },
  "tools": {
    "alsoAllow": [
      "ollama_web_search",
      "ollama_web_fetch"
    ],
    "profile": "coding",
    "web": {
      "fetch": {
        "enabled": true
      },
      "search": {
        "enabled": true
      }
    }
  }
}
